# Copiar a .env (local) o configurar en Railway (producción).

# Supabase (proyecto NUEVO, aparte del de Collab)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (NUNCA exponer al frontend)

# Llaves que pone Collab (no el cliente). Con estas se paga el consumo del cerebro.
CLAUDE_API_KEY=sk-ant-...
APIFY_API_KEY=apify_api_...

# Opcional
PORT=3001
FRONTEND_URL=https://cerebro.tudominio.com
